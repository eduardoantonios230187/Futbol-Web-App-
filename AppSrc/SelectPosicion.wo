// C:\DataFlex Projects\Futbol-Web-App-\AppSrc\SelectPosicion.wo
// SelectPosicion
//

Use cWebView.pkg
Use cWebList.pkg
Use cWebMenuGroup.pkg
Use cWebMenuItem.pkg
Use cWebColumnButton.pkg
Use cWebColumn.pkg
Use ZoomPosicion.wo

Use cposicionDataDictionary.dd

Object oSelectPosicion is a cWebView
    Set psCaption to "SelectPosicion"
    Set peWebViewStyle to wvsDrilldown
    Set peViewType to vtSelect
    Set piColumnCount to 12
    Set pbShowCaption to False
    Set piMaxWidth to 1024

    Object oposicion_DD is a cposicionDataDictionary
    End_Object 

    Set Main_DD To oposicion_DD
    Set Server  To oposicion_DD


    Object oList is a cWebList
        Set piColumnSpan to 0
        Set psCSSClass to "MobileList"
        Set pbServerOnRowClick to True
        Set pbFillHeight to True
        Set pbShowHeader to False
        Set piSortColumn to 0

        Object oposicionNombre is a cWebColumn
            Entry_Item posicion.Nombre
            Set psCaption to "posicion.Nombre"
            Set piWidth to 621
        End_Object 

        Object oDetailButton is a cWebColumnButton
            Set psCaption to "btn"
            Set piWidth to 45
            Set pbFixedWidth to True
            Set pbResizable to False
            Set piListRowSpan to 1
            Set psBtnCssClass to "WebButtonIcon WebIcon_Info"
            Set peAlign to alignRight

            WebRegisterPath ntNavigateForward oZoomPosicion
//La navegación que se produce es from main, ya que son la misma tabla

            Procedure OnClick //Se produce al hacer clic
                Send NavigatePath //Nos lleva a la vista que hayamos puesto en el WebRegisterPath
            End_Procedure

            Procedure OnGetNavigateForwardData tWebNavigateData ByRef NavigateData Handle hoToView //OnGetNavigateForwardData es un evento de navegación que se encarga de proporcionar información complementaria
                Move True to NavigateData.bReadOnly //En este caso ReadOnly
            End_Procedure

        End_Object 



        WebRegisterPath ntNavigateForward oZoomPosicion // Le indicamos a donde navegar. Utilizamos NavigateFordward porque SÍ hay intercambio de información
//La navegación que se produce es from main, ya que son la misma tabla

        Procedure OnRowClick String sRowId //Este es el procedimiento que nos servirá para pinchar sobre la fila y que nos lleve directos al ZOOM que le hemos indicado en el WebRegisterPath
            tWebNavigateData NavigateData
            Get GetNavigateData to NavigateData
            
            
//Justo aquí debajo tenemos un Case que basicamente es como un if/else en Java. Si la condición se cumple entra si no pasa y luego se sale. Aquí como condición se indica el tipo de navegación (según sea su relación)
            Case Begin
                Case (NavigateData.eNavigateType = nfFromParent)
                    Send NavigateForward of oZoomPosicion Self //Le indicamos donde debe ir en caso de que se cumpla
                    Case Break

                Case (NavigateData.eNavigateType = nfFromChild)
                    Send NavigateClose Self
                    Case Break

                Case (NavigateData.eNavigateType = nfFromMain)
                    Send NavigateClose Self
                    Case Break

                Case Else
                    Send NavigateForward of oZoomPosicion Self //Le indicamos donde debe ir en caso de que se cumpla

            Case End
        End_Procedure

        Procedure OnGetNavigateForwardData tWebNavigateData ByRef NavigateData Handle hoToView //OnGetNavigateForwardData es un evento de navegación que se encarga de proporcionar información complementaria
            Move True to NavigateData.bReadOnly //En este caso ReadOnly
        End_Procedure

    End_Object 

    Object oActionGroup is a cWebMenuGroup

        Object oSearch is a cWebMenuItem
            Set psCSSClass to "WebPromptMenuItem"
            Set psCaption to "Search"

            Procedure OnClick //Al hacer clic
                Send Search of oList //Buscamos en la lista
            End_Procedure

        End_Object 

        Object oNewButton is a cWebMenuItem
            Set psCSSClass to "WebClearMenuItem"
            Set psCaption to "New"

            WebRegisterPath ntNavigateForward oZoomPosicion

            Procedure OnClick //Al hacer clic
                Send NavigatePath //Nos lleva a la vista que hayamos colocado en el WebRegisterPath
            End_Procedure

            Procedure OnGetNavigateForwardData tWebNavigateData ByRef NavigateData Handle hoToView //OnGetNavigateForwardData es un evento de navegación que se encarga de proporcionar información complementaria
                Move True to NavigateData.bNewRecord //En este caso NewRecord
            End_Procedure

        End_Object 
    End_Object 

    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject  //OnNavigateFordward. Usará OnNavigateForward es un evento que nos puede servir para cambiar los títulos y etiquetas proporcionando así más información al usuario o para ocultar y mostrar botones según cómo se utilice esta vista. hoInvokingView Integer hoInvokingObject es el identificador de la vista que la invocó y el objeto que la invocó respectivamente
        WebSet pbRender of oNewButton to True
        WebSet pbRender of oDetailButton to True

        Case Begin
            Case (NavigateData.eNavigateType = nfFromParent)
                // If from parent, this is a constrained drill down
                Case Break

            Case (NavigateData.eNavigateType = nfFromChild)
                // If from child, this is a probably a parent lookup from a Zoom
                Case Break

            Case (NavigateData.eNavigateType = nfFromMain)
                // If from main, this is a probably a main-file lookup from a Zoom
                WebSet pbRender of oDetailButton to False
                Case Break

            Case Else // must be nfUndefined
                // This may be the start of a drilldown query or this may be used for some kind of custom query.

        Case End

    End_Procedure


End_Object 
