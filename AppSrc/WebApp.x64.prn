37736>>>    Procedure SetActionButtons
37739>>>        tWebNavigateData NavigateData
37739>>>        tWebNavigateData NavigateData
37739>>>        Boolean bHasRecord
37739>>>        Handle hoDD
37739>>>
37739>>>        Get Server to hoDD
37740>>>        Get GetNavigateData to NavigateData
37741>>>        Get HasRecord of hoDD to bHasRecord
37742>>>
37742>>>        // let's hide all buttons and then Show the ones we want
37742>>>        WebSet pbRender of oEditBtn to False
37743>>>        WebSet pbRender of oSaveBtn to False
37744>>>        WebSet pbRender of oCancelChangesBtn to False
37745>>>        WebSet pbRender of oDeleteBtn to False
37746>>>
37746>>>        If (NavigateData.bReadOnly) Begin
37748>>>            WebSet pbRender of oEditBtn to True
37749>>>        End
37749>>>>
37749>>>        Else Begin
37750>>>            WebSet pbRender of oSaveBtn to True
37751>>>            WebSet pbRender of oCancelChangesBtn to True
37752>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37753>>>        End
37753>>>>
37753>>>    End_Procedure
37754>>>
37754>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
37757>>>        // Close after save
37757>>>        Send NavigateClose Self
37758>>>    End_Procedure
37759>>>
37759>>>    // this will close the view after a delete
37759>>>    Procedure OnViewDeleted Handle hoDDO
37762>>>        Send NavigateClose Self
37763>>>    End_Procedure
