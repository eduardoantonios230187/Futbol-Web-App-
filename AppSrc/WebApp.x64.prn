37764>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37767>>>        Case Begin
37767>>>            Case (NavigateData.eNavigateType = nfFromMain)
37769>>>                // If from main, this is a propbably a main file Select to Zoom.
37769>>>                Case Break
37770>>>
37770>>>            Case (NavigateData.eNavigateType = nfFromParent)
37773>>>                // If from parent, this is a constrained drill down.
37773>>>                Case Break
37774>>>
37774>>>            Case (NavigateData.eNavigateType = nfFromChild)
37777>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37777>>>                Case Break
37778>>>
37778>>>            Case Else // must be nfUndefined
37778>>>
37778>>>        Case End
37778>>>
37778>>>        Send SetActionButtons
37779>>>
37779>>>    End_Procedure
37780>>>
37780>>>End_Object 
