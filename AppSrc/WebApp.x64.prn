38491>>>                // If from main, this is a propbably a main file Select to Zoom.
38491>>>                Case Break
38492>>>
38492>>>            Case (NavigateData.eNavigateType = nfFromParent)
38495>>>                // If from parent, this is a constrained drill down.
38495>>>                Case Break
38496>>>
38496>>>            Case (NavigateData.eNavigateType = nfFromChild)
38499>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38499>>>                Case Break
38500>>>
38500>>>            Case Else // must be nfUndefined
38500>>>
38500>>>        Case End
38500>>>
38500>>>        Send SetActionButtons
38501>>>
38501>>>    End_Procedure
