38458>>>                Case Break
38459>>>
38459>>>            Case (NavigateData.eNavigateType = nfFromParent)
38462>>>                // If from parent, this is a constrained drill down.
38462>>>                Case Break
38463>>>
38463>>>            Case (NavigateData.eNavigateType = nfFromChild)
38466>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38466>>>                Case Break
38467>>>
38467>>>            Case Else // must be nfUndefined
38467>>>
38467>>>        Case End
38467>>>
38467>>>        Send SetActionButtons
38468>>>
38468>>>    End_Procedure
38469>>>
38469>>>End_Object 
