38425>>>    Procedure SetActionButtons
38428>>>        tWebNavigateData NavigateData
38428>>>        tWebNavigateData NavigateData
38428>>>        Boolean bHasRecord
38428>>>        Handle hoDD
38428>>>
38428>>>        Get Server to hoDD
38429>>>        Get GetNavigateData to NavigateData
38430>>>        Get HasRecord of hoDD to bHasRecord
38431>>>
38431>>>        // let's hide all buttons and then Show the ones we want
38431>>>        WebSet pbRender of oEditBtn to False
38432>>>        WebSet pbRender of oSaveBtn to False
38433>>>        WebSet pbRender of oCancelChangesBtn to False
38434>>>        WebSet pbRender of oDeleteBtn to False
38435>>>
38435>>>        If (NavigateData.bReadOnly) Begin
38437>>>            WebSet pbRender of oEditBtn to True
38438>>>        End
38438>>>>
38438>>>        Else Begin
38439>>>            WebSet pbRender of oSaveBtn to True
38440>>>            WebSet pbRender of oCancelChangesBtn to True
38441>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38442>>>        End
38442>>>>
38442>>>    End_Procedure
38443>>>
