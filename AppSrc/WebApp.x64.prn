38458>>>    Procedure SetActionButtons
38461>>>        tWebNavigateData NavigateData
38461>>>        tWebNavigateData NavigateData
38461>>>        Boolean bHasRecord
38461>>>        Handle hoDD
38461>>>
38461>>>        Get Server to hoDD
38462>>>        Get GetNavigateData to NavigateData
38463>>>        Get HasRecord of hoDD to bHasRecord
38464>>>
38464>>>        // let's hide all buttons and then Show the ones we want
38464>>>        WebSet pbRender of oEditBtn to False
38465>>>        WebSet pbRender of oSaveBtn to False
38466>>>        WebSet pbRender of oCancelChangesBtn to False
38467>>>        WebSet pbRender of oDeleteBtn to False
38468>>>
38468>>>        If (NavigateData.bReadOnly) Begin
38470>>>            WebSet pbRender of oEditBtn to True
38471>>>        End
38471>>>>
38471>>>        Else Begin
38472>>>            WebSet pbRender of oSaveBtn to True
38473>>>            WebSet pbRender of oCancelChangesBtn to True
38474>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38475>>>        End
38475>>>>
38475>>>    End_Procedure
