37727>>>    Procedure SetActionButtons
37730>>>        tWebNavigateData NavigateData
37730>>>        tWebNavigateData NavigateData
37730>>>        Boolean bHasRecord
37730>>>        Handle hoDD
37730>>>
37730>>>        Get Server to hoDD
37731>>>        Get GetNavigateData to NavigateData
37732>>>        Get HasRecord of hoDD to bHasRecord
37733>>>
37733>>>        // let's hide all buttons and then Show the ones we want
37733>>>        WebSet pbRender of oEditBtn to False
37734>>>        WebSet pbRender of oSaveBtn to False
37735>>>        WebSet pbRender of oCancelChangesBtn to False
37736>>>        WebSet pbRender of oDeleteBtn to False
37737>>>
37737>>>        If (NavigateData.bReadOnly) Begin
37739>>>            WebSet pbRender of oEditBtn to True
37740>>>        End
37740>>>>
37740>>>        Else Begin
37741>>>            WebSet pbRender of oSaveBtn to True
37742>>>            WebSet pbRender of oCancelChangesBtn to True
37743>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37744>>>        End
37744>>>>
37744>>>    End_Procedure
37745>>>
37745>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged //OnViewSaved es un evento que se produce después de un guardado de vista exitoso (Request_Save). Un guardado es exitoso si no hubo errores 
37748>>>        // Close after save
37748>>>        Send NavigateClose Self //En este caso lo que hace es cerrar la vista y llevarnos a la vista de la que venimos
37749>>>    End_Procedure
37750>>>
37750>>>    // this will close the view after a delete
37750>>>    Procedure OnViewDeleted Handle hoDDO //OnViewDeleted es un evento que se produce después de una eliminación de exitosa (Request_Delete). Una eliminación es exitosa si no hubo errores 
37753>>>        Send NavigateClose Self //En este caso lo que hace es cerrar la vista y llevarnos a la vista de la que venimos
37754>>>    End_Procedure
37755>>>
37755>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37758>>>        Case Begin
37758>>>            Case (NavigateData.eNavigateType = nfFromMain)
37760>>>                // If from main, this is a propbably a main file Select to Zoom.
37760>>>                Case Break
37761>>>
37761>>>            Case (NavigateData.eNavigateType = nfFromParent)
37764>>>                // If from parent, this is a constrained drill down.
37764>>>                Case Break
37765>>>
37765>>>            Case (NavigateData.eNavigateType = nfFromChild)
37768>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37768>>>                Case Break
37769>>>
37769>>>            Case Else // must be nfUndefined
37769>>>
37769>>>        Case End
37769>>>
37769>>>        Send SetActionButtons
37770>>>
37770>>>    End_Procedure
37771>>>
37771>>>End_Object 
