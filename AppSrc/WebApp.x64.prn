38776>>>        tWebNavigateData NavigateData
38776>>>        tWebNavigateData NavigateData
38776>>>        Boolean bHasRecord
38776>>>        Handle hoDD
38776>>>
38776>>>        Get Server to hoDD
38777>>>        Get GetNavigateData to NavigateData
38778>>>        Get HasRecord of hoDD to bHasRecord
38779>>>
38779>>>        // let's hide all buttons and then Show the ones we want
38779>>>        WebSet pbRender of oEditBtn to False
38780>>>        WebSet pbRender of oSaveBtn to False
38781>>>        WebSet pbRender of oCancelChangesBtn to False
38782>>>        WebSet pbRender of oDeleteBtn to False
38783>>>
38783>>>        If (NavigateData.bReadOnly) Begin
38785>>>            WebSet pbRender of oEditBtn to True
38786>>>        End
